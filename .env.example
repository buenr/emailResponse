# Copy this file to .env and update the values as needed

# Optional: API key for your OpenAI-compatible endpoint
OPENAI_API_KEY=EMPTY

# Optional: local vLLM endpoint
VLLM_BASE_URL=http://localhost:8000/v1

# Optional: model name to use with the local endpoint
VLLM_MODEL=Qwen/Qwen3.6-27B

# Optional: OpenShift/container health endpoint port
PORT=8080

# Microsoft Graph Integration Settings (for --msgraph mode)
MSGRAPH_TENANT_ID=your-tenant-id-here
MSGRAPH_CLIENT_ID=your-client-id-here
# Optional: client secret for confidential client/daemon credentials flow
MSGRAPH_CLIENT_SECRET=your-client-secret-here
# Optional: target user email / UPN (required for client credentials flow)
MSGRAPH_USER_EMAIL=shared-inbox@yourdomain.com
# Optional configurations (True/False)
MSGRAPH_AUTO_REPLY=False
MSGRAPH_CREATE_DRAFT=True
MSGRAPH_MARK_AS_READ=False

# Production hardening
MSGRAPH_RATE_LIMIT_TOKENS=10
MSGRAPH_RATE_LIMIT_REFILL_PER_SEC=1.0
HEALTH_PORT=8080
POLL_INTERVAL_SECONDS=60

# Container/OpenShift daemon mode
EMAIL_AGENT_DAEMON=false
EMAIL_AGENT_AUTO_REPLY=False
EMAIL_AGENT_CREATE_DRAFT=True
EMAIL_AGENT_MARK_READ=False
EMAIL_AGENT_LIMIT=10
EMAIL_AGENT_TIME_WINDOW_MINUTES=5
EMAIL_AGENT_POLL_INTERVAL_SECONDS=60

